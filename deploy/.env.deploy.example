# Configuración de Despliegue para Hostinger VPS
# Copia este archivo a .env.deploy y configura tus valores

# Información del VPS
VPS_HOST=2.24.215.174
VPS_USER=root
VPS_PORT=22

# Rutas en el VPS
VPS_PROJECT_PATH=/var/www/krowdco
VPS_BACKUP_PATH=/var/backups/krowdco

# Configuración SSH
SSH_KEY_PATH=~/.ssh/hostinger_deploy_key

# URLs para health checks
PRODUCTION_WEB_URL=https://www.krowdco.com
PRODUCTION_API_URL=https://www.krowdco.com/api

# Configuración de despliegue
DEPLOY_TIMEOUT=300
HEALTH_CHECK_RETRIES=5
HEALTH_CHECK_DELAY=10